<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/home_fragment_basic_id">


    <fragment
        android:id="@id/home_fragment_basic_id"
        android:name="com.gogcompany.mymvvmapplication.presentation.home.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_home_fragment_basic_id_to_note_fragment_basic_id"
            app:destination="@id/note_fragment_basic_id" />
    </fragment>
    <fragment
        android:id="@id/note_fragment_basic_id"
        android:name="com.gogcompany.mymvvmapplication.presentation.note.NoteFragment"
        android:label="fragment_note"
        tools:layout="@layout/fragment_note" >
        <argument
            android:name="note"
            app:argType="com.gogcompany.mymvvmapplication.data.local.model.Note"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>
    <fragment
        android:id="@+id/DBindingFragment"
        android:name="com.gogcompany.mymvvmapplication.presentation.dataBinding.DBindingFragment"
        android:label="DBindingFragment" />
</navigation>