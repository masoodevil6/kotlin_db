<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    tools:context=".presentation.note.NoteFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@id/note_fragment_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gray"
        app:menu="@menu/menu_note"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:title="Note Add/Edit"
        />


    <com.google.android.material.textfield.TextInputLayout
        android:id="@id/note_fragment_edit_text_note_title_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:startIconDrawable="@drawable/ic_title"
        app:layout_constraintTop_toBottomOf="@id/note_fragment_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:gravity="start|top"
        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@id/note_fragment_edit_text_note_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Title ..."
            android:paddingStart="8dp"
            android:minLines="1"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            />

    </com.google.android.material.textfield.TextInputLayout>






    <com.google.android.material.textfield.TextInputLayout
        android:id="@id/note_fragment_edit_text_note_description_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:startIconDrawable="@drawable/ic_description"
        app:layout_constraintTop_toBottomOf="@id/note_fragment_edit_text_note_title_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:gravity="start|top"
        >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@id/note_fragment_edit_text_note_description"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:hint="Description ..."
            android:paddingStart="8dp"
            android:minLines="3"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            />

    </com.google.android.material.textfield.TextInputLayout>

    
    <com.google.android.material.button.MaterialButton
        android:id="@id/note_fragment_edit_btn_submit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:text="Save"
        app:icon="@drawable/ic_save"
        app:iconPadding="8dp"
        />


</androidx.constraintlayout.widget.ConstraintLayout>